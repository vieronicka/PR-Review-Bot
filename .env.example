# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# GitHub: create a fine-grained Personal Access Token at
# https://github.com/settings/tokens?type=beta
# Scopes for Phase 1: Repository → Contents (Read), Pull requests (Read)
# Phase 3 (--post): also enable Pull requests (Write)
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username (used to only review PRs you opened)
GITHUB_USERNAME=your-github-username

# Phase 2 — LLM provider: gemini (default) or openai
LLM_PROVIDER=gemini

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — https://platform.openai.com/api-keys (set LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini
